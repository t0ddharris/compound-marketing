# Google AI Studio API key — used for image generation (blog heroes, social graphics, illustrations, etc.)
# Used by the image-gen skill and the blog skill's Step 5.5
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=

# HubSpot Private App Token — used by the analytics skill
# Create at: Settings > Integrations > Private Apps
# Required scopes: content, business-intelligence, marketing.campaigns.read, forms
HUBSPOT_PRIVATE_APP_TOKEN=

# LinkedIn — used by the analytics skill for page/post metrics
# See .claude/skills/analytics/setup/linkedin-setup.md
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

# X / Twitter — used by the analytics skill for post metrics
# See .claude/skills/analytics/setup/x-setup.md
X_BEARER_TOKEN=
X_USERNAME=

# YouTube — used by the analytics skill for channel/video metrics
# See .claude/skills/analytics/setup/youtube-setup.md
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_CHANNEL_ID=

# Granola API key — used for pulling meeting notes
# Generate at: Granola desktop app > Settings > API > Create new key
# Requires Business or Enterprise plan
GRANOLA_API_KEY=
